<section id="contact-section" class="py-5" style="background-color: #f8f9fa; border-top: 1px solid #e9ecef;">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-lg-8">
        <div class="card border-0 shadow-sm rounded-4 p-4 p-md-5" style="background: white;">
          <h2 class="text-center mb-4" style="font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; font-weight: 700;">Get In Touch</h2>
          <p class="text-center text-muted mb-4">Prefer to send us a message instead of booking a call? Fill out the form below and our team will get back to you shortly.</p>
          
          <form id="embeddedContactForm" action="/contact_notification" method="post" accept-charset="UTF-8">
            <div class="row">
              <div class="col-md-6 mb-3">
                <div class="form-floating">
                  <input type="text" name="contact[FirstName]" class="form-control" id="embedFirstName" required placeholder="First Name" />
                  <label for="embedFirstName">First Name *</label>
                </div>
              </div>
              <div class="col-md-6 mb-3">
                <div class="form-floating">
                  <input type="text" name="contact[LastName]" class="form-control" id="embedLastName" required placeholder="Last Name" />
                  <label for="embedLastName">Last Name *</label>
                </div>
              </div>
            </div>
            
            <div class="row">
              <div class="col-md-6 mb-3">
                <div class="form-floating">
                  <input type="email" name="contact[Email]" class="form-control" id="embedEmail" required placeholder="Email" />
                  <label for="embedEmail">Email *</label>
                </div>
              </div>
              <div class="col-md-6 mb-3">
                <div class="form-floating">
                  <input type="tel" name="contact[MobilePhone]" class="form-control" id="embedPhone" placeholder="Mobile Phone" />
                  <label for="embedPhone">Mobile Phone</label>
                </div>
              </div>
            </div>
            
            <div class="form-floating mb-4">
              <textarea name="contact[Contact_Form_Message]" class="form-control" id="embedMessage" placeholder="Message" style="height: 120px" required></textarea>
              <label for="embedMessage">Message *</label>
            </div>
            
            <input type="text" name="h_5c972f06be11bb485b8901a14ec8d41f359cd881" value="" style="display:none">
            <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
            
            <div class="text-center">
              <button type="submit" class="btn rounded-pill px-5 py-3" style="background-color: #1D1D1F; color: white; font-weight: 600; width: 100%; max-width: 300px; transition: all 0.2s ease;">Send Message</button>
              <p class="text-muted small mt-3">We'll never share your info with anyone.</p>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const form = document.getElementById('embeddedContactForm');
  let isSubmitting = false;
  
  if (form) {
    form.addEventListener('submit', function(e) {
      e.preventDefault();
      
      const fnVal = (form.querySelector('#embedFirstName')?.value || '').trim().toLowerCase();
      const lnVal = (form.querySelector('#embedLastName')?.value || '').trim().toLowerCase();
      if (fnVal && lnVal && fnVal === lnVal) {
        window.location.href = '/thank-you';
        return;
      }

      if (isSubmitting) return;
      
      const firstNameField = form.querySelector('#embedFirstName');
      const lastNameField = form.querySelector('#embedLastName');
      const emailField = form.querySelector('#embedEmail');
      const messageField = form.querySelector('#embedMessage');
      
      if (!firstNameField.value.trim() || !lastNameField.value.trim() || !emailField.value.trim() || !messageField.value.trim()) {
        return; // Native required attributes catch empty fields
      }
      
      isSubmitting = true;
      const submitBtn = form.querySelector('button[type="submit"]');
      const originalValue = submitBtn.textContent;
      submitBtn.textContent = 'Sending...';
      submitBtn.disabled = true;
      
      fetch('/contact_notification', {
        method: 'POST',
        body: new FormData(form),
        headers: {
          'X-Requested-With': 'XMLHttpRequest',
          'Accept': 'application/json'
        }
      })
      .then(response => {
        if (!response.ok) throw new Error('Network error');
        return response.json();
      })
      .then(data => {
        if (data.success) {
          window.location.href = '/thank-you';
        } else {
          alert('Error: ' + (data.message || 'Failed to send message'));
          submitBtn.textContent = originalValue;
          submitBtn.disabled = false;
          isSubmitting = false;
        }
      })
      .catch(error => {
        alert('An error occurred. Please try again.');
        submitBtn.textContent = originalValue;
        submitBtn.disabled = false;
        isSubmitting = false;
      });
    });
  }
});
</script>
