<section id="reviews" class="bg-light">
  <div class="container px-4 py-5">
    <div class="">
      <h2 class="pb-4 m-3 text-center">We pride ourselves in providing the best service</h2>
    </div>
    <div class="row px-4">
      <% if @reviews.present? && @reviews["records"].present? %>
        <%
          all_reviews = @reviews["records"]
          displayed_reviews = all_reviews
            .sort_by { |r| [r["featured"] == true ? 0 : 1, r["id"].to_i] }
            .first(12)
        %>
        <% displayed_reviews.each do |review| %>
          <div class="col-sm-6 col-md-4 col-lg-3 px-2 py-2">
            <%= render "main_page_sections/review_card", review: review %>
          </div>
        <% end %>
        <% if all_reviews.size > displayed_reviews.size %>
          <div class="col-12 text-center pt-3">
            <a href="/reviews" class="btn btn-outline-secondary rounded-pill px-4">View all reviews</a>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>
</section>
