<% content_for :title, @mtitle %>
<% content_for :meta_description, @mdescription %>

<!-- Hero Section -->
<section class="py-5" style="background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-lg-10 text-center">
        <h1 class="display-4 fw-bold mb-4">
          Legal News & Insights
        </h1>
        <p class="lead mb-4">
          Stay informed with the latest updates on Spanish property law, holiday rental regulations, 
          and expert legal guidance from our experienced team at Roper Lawyers.
        </p>
      </div>
    </div>
  </div>
</section>

<!-- Blog Posts Section -->
<section class="py-5">
  <div class="container">
    <div class="row">
      
      <!-- Featured Article: Tourist Use Trap -->
      <div class="col-lg-8 mb-5">
        <article class="card border-0 shadow-sm h-100">
          <div class="card-body p-4">
            <div class="d-flex align-items-center mb-3">
              <span class="badge rounded-pill me-2" style="background-color: #b39c84;">Featured Report</span>
              <small class="text-muted">2026</small>
            </div>
            
            <h2 class="card-title h3 mb-3">
              <a href="/canary-islands-tourist-use-legal-trap" class="text-decoration-none text-dark">
                Don’t Buy a Property in The Canary Islands Until You Watch This!
              </a>
            </h2>
            
            <p class="card-text mb-4">
              Former Town Hall Counselor Olivier Roper explains the "Tourist Use" legal trap. In many popular areas, owning the title deed does not grant residential rights. Learn about Suelo Turístico and Decree-Law 2/2025 before you invest.
            </p>

            <div class="ratio ratio-16x9 mb-4">
              <iframe
                src="https://www.youtube.com/embed/5XAROjYLqy0"
                title="Canary Islands Tourist Use Legal Trap Video"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                allowfullscreen
                loading="lazy"></iframe>
            </div>
            
            <div class="d-flex flex-column flex-sm-row gap-3">
              <a href="/canary-islands-tourist-use-legal-trap" class="btn rounded-pill" style="background-color: #b39c84; border-color: #b39c84; color: white;">
                Watch & Read Guide
              </a>
              <a href="#" data-bs-toggle="modal" data-bs-target="#contactModal" class="btn btn-outline-secondary rounded-pill">
                Secure Conveyancing
              </a>
            </div>
          </div>
        </article>
      </div>

      <!-- Article List -->
      <div class="col-lg-8 mb-5">
        <article class="card border-0 shadow-sm mb-4">
          <div class="card-body p-4">
            <div class="d-flex align-items-center mb-3">
              <span class="badge rounded-pill me-2" style="background-color: #6c757d;">Legal Update</span>
              <small class="text-muted">2026</small>
            </div>
            
            <h2 class="card-title h4 mb-3">
              <a href="/canary-islands-holiday-rental-laws" class="text-decoration-none text-dark">
                Canary Islands Holiday Rental Laws 2026: NRA & N2 Compliance
              </a>
            </h2>
            
            <p class="card-text mb-4">
              2026 introduces mandatory annual reporting for NRA holders and new compliance risks for holiday rentals. Missing the N2 deadline risks NRA revocation and immediate delisting.
            </p>

            <div class="ratio ratio-16x9 mb-4">
              <iframe
                src="https://www.youtube.com/embed/eNsGdYoUuHE"
                title="Canary Islands Holiday Rental Laws 2026 Video"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                allowfullscreen
                loading="lazy"></iframe>
            </div>

            <a href="/canary-islands-holiday-rental-laws" class="btn btn-sm btn-outline-dark rounded-pill">Read More</a>
          </div>
        </article>
      </div>
      
      <!-- Sidebar -->
      <div class="col-lg-4">
        
        <!-- Recent Articles -->
        <div class="card border-0 shadow-sm mb-4">
          <div class="card-header bg-white border-0">
            <h4 class="h5 mb-0">Recent Articles</h4>
          </div>
          <div class="card-body">
            <div class="mb-3 pb-3 border-bottom">
              <h6 class="mb-2">
                <a href="/n2-reporting-guide" class="text-decoration-none text-dark">
                  N2 Reporting Guide 2026
                </a>
              </h6>
              <small class="text-muted">Mandatory Annual Informative Declaration steps for property owners</small>
            </div>
            
            <div class="mb-3 pb-3 border-bottom">
              <h6 class="mb-2">
                <a href="/property-buying-guide" class="text-decoration-none text-dark">
                  Complete Guide to Buying Property in Spain
                </a>
              </h6>
              <small class="text-muted">Essential steps, legal requirements, and expert tips for UK and Irish buyers</small>
            </div>
            
            <div class="mb-3 pb-3 border-bottom">
              <h6 class="mb-2">
                <a href="/holiday-rental-license" class="text-decoration-none text-dark">
                  VV License Application Process
                </a>
              </h6>
              <small class="text-muted">Step-by-step guide to obtaining your holiday rental license in Spain</small>
            </div>
            
            <div class="mb-3 pb-3 border-bottom">
              <h6 class="mb-2">
                <a href="/wills" class="text-decoration-none text-dark">
                  Spanish Wills for Property Owners
                </a>
              </h6>
              <small class="text-muted">Why you need a Spanish will and how to ensure proper inheritance planning</small>
            </div>
            
            <div class="mb-0">
              <h6 class="mb-2">
                <a href="/selling-property" class="text-decoration-none text-dark">
                  Selling Property in Spain: Legal Requirements
                </a>
              </h6>
              <small class="text-muted">Tax obligations, legal procedures, and expert guidance for property sales</small>
            </div>
          </div>
        </div>
        
        <!-- Categories -->
        <div class="card border-0 shadow-sm mb-4">
          <div class="card-header bg-white border-0">
            <h4 class="h5 mb-0">Categories</h4>
          </div>
          <div class="card-body">
            <div class="d-flex flex-wrap gap-2">
              <a href="/buying-property" class="badge rounded-pill text-decoration-none" style="background-color: #b39c84; color: white;">Property Buying</a>
              <a href="/selling-property" class="badge rounded-pill text-decoration-none" style="background-color: #b39c84; color: white;">Property Selling</a>
              <a href="/holiday-rental-license" class="badge rounded-pill text-decoration-none" style="background-color: #b39c84; color: white;">Holiday Rentals</a>
              <a href="/wills" class="badge rounded-pill text-decoration-none" style="background-color: #b39c84; color: white;">Wills & Inheritance</a>
              <a href="/services" class="badge rounded-pill text-decoration-none" style="background-color: #b39c84; color: white;">Legal Services</a>
            </div>
          </div>
        </div>
        
        <!-- Contact CTA -->
        <div class="card border-0 text-white" style="background-color: #b39c84;">
          <div class="card-body text-center">
            <h5 class="card-title">Need Legal Advice?</h5>
            <p class="card-text">Our experienced bilingual lawyers are here to help with all aspects of Spanish property law.</p>
            <a href="#" data-bs-toggle="modal" data-bs-target="#contactModal" class="btn btn-light rounded-pill">
              Get Free Consultation
            </a>
          </div>
        </div>
        
      </div>
    </div>
  </div>
</section>

<!-- Reviews Section -->
<%= render 'main_page_sections/reviews' %>
