<% content_for :title, @mtitle %>
<% content_for :description, @mdescription %>

<div class="container-fluid px-0">
<%= render layout: "main_page_sections/page_hero",
           locals: {
             title: "Client Reviews & Testimonials",
             intro: "Read genuine reviews from our satisfied clients across Spain and the Canary Islands. See why UK, Irish & international property buyers trust Roper Lawyers for their Spanish property transactions."
           } do %>
  <div class="d-flex justify-content-center align-items-center gap-3 mb-0">
    <div class="text-center">
      <div class="h2 mb-0 d-flex justify-content-center">
        <% 5.times do |i| %>
          <svg width="24" height="24" viewBox="0 0 24 24" class="<%= 'me-1' if i < 4 %>" fill="#FBBC04" aria-hidden="true">
            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
          </svg>
        <% end %>
      </div>
      <p class="mb-0 text-muted"><%= SchemaHelper::GBP_RATING_VALUE %> out of 5 stars</p>
    </div>
    <div class="text-center">
      <div class="h3 mb-0 fw-bold" style="color: #b39c84;"><%= SchemaHelper::GBP_REVIEW_COUNT %></div>
      <p class="mb-0 text-muted">Reviews</p>
    </div>
  </div>
<% end %>

  <!-- Reviews Section -->
  <section id="all-reviews" class="py-5">
    <div class="container">
      <div class="row g-4">
        <% if @reviews && @reviews["records"] %>
          <% @reviews["records"].sort_by { |r| [r["featured"] == true ? 0 : 1, r["id"].to_i] }.each do |review| %>
            <div class="col-lg-4 col-md-6">
              <%= render "main_page_sections/review_card", review: review %>
            </div>
          <% end %>
        <% else %>
          <div class="col-12 text-center py-5">
            <p class="text-muted">Reviews are currently being loaded. Please check back soon.</p>
          </div>
        <% end %>
      </div>

      <p class="text-center mt-4 mb-0">
        <a href="<%= SchemaHelper::GOOGLE_BUSINESS_PROFILE_URL %>"
           target="_blank"
           rel="noopener noreferrer"
           class="small text-muted text-decoration-none">
          Read all our reviews on Google ↗
        </a>
      </p>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="text-white py-5" style="background-color: #b39c84;">
    <div class="container">
      <div class="row justify-content-center">
        <div class="col-lg-8 text-center">
          <h3 class="mb-3">Ready to Join Our Happy Clients?</h3>
          <p class="lead mb-4">
            Get expert legal guidance for your Spanish property transaction.
            Free consultation with our bilingual legal team.
          </p>
          <div class="d-flex flex-column flex-sm-row gap-3 justify-content-center">
            <a href="/free-consultation" class="btn btn-light btn-lg rounded-pill px-4">
              Book Free Consultation
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</div>
