              </svg>
              </div>
            </a>
          </div>

          <!-- Scarcity Message -->
          <div class="mb-4">
            <div class="d-inline-flex align-items-center px-3 py-2 rounded-pill" 
                 style="background-color: rgba(179, 156, 132, 0.08); border: 1px solid rgba(179, 156, 132, 0.2);">
              <span style="color: #b39c84; font-weight: 500; font-size: 0.85rem;">
                Limited to <%= pick_random_number_based_on_month %> clients this <%= Date.current.strftime("%B") %> for best service.
              </span>
              <a href="#" class="text-decoration-none d-inline-flex align-items-center secondary-link ms-2" 
                 data-bs-toggle="modal" data-bs-target="#contactModal"
                 style="color: #212529; font-weight: 500; font-size: 0.85rem; transition: all 0.2s ease;">
                <span class="link-text">Contact us</span> <span class="arrow ms-1">→</span>
