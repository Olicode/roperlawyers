           <!-- Secondary CTA -->
           <a href="#contactModal" data-bs-toggle="modal" class="btn rounded-pill d-flex align-items-center justify-content-center text-decoration-none hero-secondary-btn" 
              style="color: #000000; background-color: #f8f9fa; border: none; font-weight: 400; font-size: 1.125rem; padding: 0.75rem 1.5rem; min-height: 48px; width: fit-content; transition: background-color 0.2s ease;">
             <span style="font-size: 1.125rem; font-weight: 400;">Contact Us</span>
