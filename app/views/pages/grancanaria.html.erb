            </div>
          </div>

          <!-- Main Headline -->
          <h1 class="hero-headline mb-4" style="font-size: 2.8rem; font-weight: 700; line-height: 1.1; color: #1a1a1a; letter-spacing: 0.5px;">
            <span class="gradient-text">Gran Canaria Property</span> Lawyers:<br>
            Expert Conveyancing & Legal Services
          </h1>

          <!-- Subheadline -->
          <p class="hero-subtext mb-5" style="font-size: 1.125rem; color: #212529; line-height: 1.5; max-width: 90%;">
            We specialise in providing you with clear, concise, and trustworthy legal advice to facilitate a stress-free property purchase in Gran Canaria. With over 12 years of experience, our bilingual team is committed to ensuring your peace of mind throughout the transaction.
          </p>

          <!-- CTA Buttons -->
          <div class="d-flex flex-column flex-sm-row gap-3 mb-3 align-items-start">
            <!-- Primary CTA Column -->
            <div class="d-flex flex-column align-items-start">
              <a href="/free-consultation" class="btn rounded-pill d-flex align-items-center justify-content-center hero-primary-btn" 
                 style="background-color: #b39c84; border: none; color: white; padding: 0.75rem 1.5rem; font-size: 1.125rem; text-decoration: none; width: fit-content; min-height: 48px; transition: background-color 0.2s ease;">
                <span style="font-size: 1.125rem; font-weight: 500; letter-spacing: 0.8px;">Book Free Consultation</span>
              </a>
              
              <!-- Button Subtext -->
              <div class="mt-2 d-flex align-items-center justify-content-center" style="font-size: 0.85rem; color: #6c757d; width: 100%;">
                <%= image_tag("Olivier-Roper-Solicitor-Roper-Lawyers-head.jpg", 
                    alt: "Olivier Roper", 
                    class: "rounded-circle me-2",
                    style: "width: 24px; height: 24px; object-fit: cover;") %>
                Speak directly to Olivier Roper
              </div>
