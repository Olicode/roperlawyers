<style>
/* Mobile sticky contact bar - Modern Apple-like */
.mobile-contact-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: transparent; /* Removed full-width white bar */
  backdrop-filter: none;
  -webkit-backdrop-filter: none;
  border-top: none;
  padding: 12px 16px;
  z-index: 1000;
  display: flex;
  justify-content: center;
  align-items: center;
  padding-bottom: calc(12px + env(safe-area-inset-bottom)); /* iOS safe area */
  pointer-events: none; /* Allows scrolling on the invisible areas around the buttons */
}

.mobile-buttons-container {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  width: 100%;
  max-width: 450px;
  pointer-events: auto; /* Re-enables clicking on the buttons themselves */
}

/* Primary Profile Capsule Button */
.mobile-contact-btn-capsule {
  background-color: rgba(255, 255, 255, 0.90); /* Subtle glass white */
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  padding: 6px 16px 6px 6px;
  border-radius: 50px; /* Capsule shape */
  text-decoration: none;
  display: flex;
  align-items: center;
  flex: 1; /* Takes up main space */
  transition: all 0.2s ease;
  border: 1px solid rgba(229, 229, 234, 0.8); /* Subtle light grey border */
  box-shadow: 0 4px 20px rgba(0,0,0,0.1); /* Slightly stronger shadow since it floats */
}

.mobile-contact-btn-capsule:active {
  transform: scale(0.98);
  background-color: #f2f2f7;
}

.capsule-avatar {
  width: 42px;
  height: 42px;
  border-radius: 50%;
  object-fit: cover;
  margin-right: 12px;
}

.capsule-text {
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.capsule-title {
  font-size: 0.95rem; /* ~15px */
  font-weight: 600;
  color: #1D1D1F;
  line-height: 1.2;
  margin-bottom: 2px;
}

.capsule-subtitle {
  font-size: 0.8rem; /* ~13px */
  font-weight: 500;
  color: #6C757D;
  line-height: 1.2;
}

/* WhatsApp Circle Button */
.mobile-contact-btn-circle {
  background-color: #25D366;
  width: 50px;
  height: 50px;
  border-radius: 50%;
  text-decoration: none;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: all 0.2s ease;
  border: none;
  box-shadow: 0 4px 12px rgba(37, 211, 102, 0.3); /* Soft green glow */
}

.mobile-contact-btn-circle:active {
  transform: scale(0.95);
  background-color: #1DA851;
}

.whatsapp-icon-white {
  width: 28px;
  height: 28px;
  color: #FFFFFF; /* Pure white SVG inside green circle */
}

/* Body padding adjustment */
@media (max-width: 768px) {
  body {
    padding-bottom: 90px; 
  }
}
</style>
