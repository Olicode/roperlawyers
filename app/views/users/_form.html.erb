<%= form_with(model: user, html: { data: { controller: "user-form" }, novalidate: true }) do |form| %>
  <div class="row justify-content-center">
    <div class="col-11 col-md-10 col-lg-6 px-3 px-md-0">

      <h1 style="font-family: 'Times New Roman', Times, serif; color: #b29c84; text-align: center; margin-top: 3rem; margin-bottom: 1rem; letter-spacing: 0.2em;">ROPER LAWYERS</h1>

      <div class="text-center m-3">
        <h2 class="mb-3" style="font-size: 1.6rem;">Information Required</h2>
        <p style="font-size: 1.05rem; line-height: 1.7; color: #555;">
          Please fill in the details below so we can handle your matter efficiently.<br>
          Don't worry if you're unsure of anything — you can always log back in and update it later.<br>
          <strong>We'll be notified of any changes and will review them accordingly.</strong>
        </p>
      </div>

      <!-- Progress Bar -->
      <div class="form-progress-bar" data-user-form-target="progressBar">
        <div class="form-progress-track">
          <div class="form-progress-fill" data-user-form-target="progressFill" style="width: 0%"></div>
        </div>
        <div class="form-progress-steps" data-user-form-target="progressSteps">
          <span class="progress-step active" data-section="services">Services</span>
          <span class="progress-step" data-section="identity">Identity</span>
          <span class="progress-step" data-section="legal">Legal</span>
          <span class="progress-step" data-section="details">Details</span>
          <span class="progress-step" data-section="documents">Documents</span>
        </div>
      </div>

      <% if user.errors.any? %>
        <div id="error_explanation" class="alert alert-danger" style="font-size: 1.05rem;">
          <%= pluralize(user.errors.count, "error") %> prohibited this form from being saved:
          <ul>
            <% user.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <!-- Step 1: Services — "What do you need?" -->
      <div data-progress-section="services">
        <%= render_user_form_section(form, :requested_services, user) %>
      </div>

      <!-- Step 2: Identity — "Who are you?" -->
      <div data-progress-section="identity">
        <%= render_user_form_section(form, :personal, user) %>
        <%= render_user_form_section(form, :passport, user) %>
        <%= render_user_form_section(form, :nie_information, user) %>
      </div>

      <!-- Step 3: Legal decisions -->
      <div data-progress-section="legal">
        <%= render_user_form_section(form, :power_of_attorney, user, id: "section_poa", "data-user-form-target": "poaSection") %>
      </div>

      <!-- Step 4: Conditional details -->
      <div data-progress-section="details">
        <%= render_user_form_section(form, :property_sale, user, id: "section_property_sale", "data-user-form-target": "sectionSale", style: "display:none") %>

        <%= render_user_form_section(form, :new_build_declaration, user, id: "section_new_build", "data-user-form-target": "sectionNewBuild", style: "display:none") %>

        <div class="card p-5 mb-5 card-shadow" id="section_property_purchase" data-user-form-target="sectionPurchase" style="display:none">
          <%= render_user_form_section(form, :property_purchase, user, no_wrapper: true) %>
          <hr class="hr mb-3" style="color: #b29c84;">
          <%= render_user_form_section(form, :bank_details, user, no_wrapper: true) %>
        </div>

        <%= render_user_form_section(form, :will_testament, user, id: "section_will", "data-user-form-target": "sectionWill", style: "display:none") %>
      </div>

      <!-- Step 5: Documents -->
      <div data-progress-section="documents">
        <%= render_user_form_section(form, :vv_license_documents, user, id: "section_documents", "data-user-form-target": "sectionDocuments", class: "card p-5 mb-3 card-shadow", style: "display:none") %>
      </div>

      <div class="d-grid mb-3">
        <button type="submit" class="btn btn-lg mb-2 form-submit-btn" data-action="click->user-form#disableOnSubmit">Submit</button>
      </div>

      <div class="mb-5 text-center" style="font-size: 1.05rem;">
        Have any questions? <a href="https://wa.me/+34649948377" style="color: #b29c84; text-decoration: none; font-weight: 600;">Send us a WhatsApp</a>
      </div>

      <p class="mt-5 mb-3 text-muted text-center">Roper Lawyers &copy; 2010-<%= Date.today.year %></p>
    </div>
  </div>
<% end %>