<div class="container-fluid flex-grow-1 d-flex align-items-center justify-content-center py-5" style="background-color: #faf9f7;">
  <div class="col-11 col-sm-8 col-md-6 col-lg-4 col-xl-3">
    <div class="card border-0 shadow-sm rounded-4 p-4 p-md-5 bg-white">
      <div class="text-center mb-4">
        <h3 class="fw-bold mb-2" style="color: #1a1a1a; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;">Welcome to Roper Lawyers</h3>
        <h5 class="text-muted mb-2" style="font-size: 1rem;">Property conveyancing solicitors</h5>
        <p class="text-muted" style="font-size: 0.95rem;">Create an account or <%= link_to "Log in", new_user_session_path, :"data-turbolinks" => false, class: "text-decoration-none fw-medium", style: "color: #b39c84;" %></p>
      </div>

      <% if resource.errors.any? %>
        <div class="alert alert-danger rounded-3 border-0 bg-danger bg-opacity-10 text-danger small py-2 px-3 mb-4">
          <h6 class="mb-2"><%= pluralize(resource.errors.count, "error") %> prohibited this registration from being saved:</h6>
          <ul class="mb-0 ps-3">
            <% resource.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { data: { turbo: false }}) do |f| %>
        
        <div class="form-floating mb-3">
          <%= f.email_field :email, class: "form-control border-0 bg-light rounded-3 shadow-none #{'is-invalid' if resource.errors[:email].any?}",
                      required: true,
                      autofocus: true,
                      autocomplete: "email",
                      placeholder: "Email address" %>
          <%= f.label :email, "Email address", class: "text-muted" %>
          
          <% if resource.errors[:email].any? %>
            <div class="invalid-feedback d-block px-2">
              <%= resource.errors[:email].join(", ") %>
            </div>
          <% end %>
        </div>

        <div class="form-floating mb-3">
          <%= f.password_field :password, class: "form-control border-0 bg-light rounded-3 shadow-none #{'is-invalid' if resource.errors[:password].any?}",
                      required: true,
                      autocomplete: "new-password",
                      placeholder: "Password" %>
          <%= f.label :password, "Password", class: "text-muted" %>
          
          <% if resource.errors[:password].any? %>
            <div class="invalid-feedback d-block px-2">
              <%= resource.errors[:password].join(", ") %>
            </div>
          <% end %>
          <div class="form-text text-muted px-2" style="font-size: 0.8rem;">
            <% if @minimum_password_length %>
              <%= @minimum_password_length %> characters minimum
            <% end %>
          </div>
        </div>

        <div class="form-floating mb-4">
          <%= f.password_field :password_confirmation, class: "form-control border-0 bg-light rounded-3 shadow-none #{'is-invalid' if resource.errors[:password_confirmation].any?}",
                      required: true,
                      autocomplete: "new-password",
                      placeholder: "Password confirmation" %>
          <%= f.label :password_confirmation, "Password confirmation", class: "text-muted" %>
          
          <% if resource.errors[:password_confirmation].any? %>
            <div class="invalid-feedback d-block px-2">
              <%= resource.errors[:password_confirmation].join(", ") %>
            </div>
          <% end %>
        </div>

        <div class="d-grid gap-2 mb-4">
          <%= f.submit "Sign up", class: "btn rounded-pill fw-medium shadow-sm py-2", style: "background-color: #b39c84; color: white; border: none; font-size: 1.05rem; transition: all 0.2s ease;" %>
        </div>
      <% end %>
      
      <div class="text-center mt-3">
        <p class="text-muted small mb-0">Have any questions? <br/> <a href="https://wa.me/+34649948377" class="text-decoration-none fw-medium" style="color: #b39c84;">Send me a WhatsApp</a></p>
      </div>
    </div>
  </div>
</div>
