<div class="container-fluid flex-grow-1 d-flex align-items-center justify-content-center py-5" style="background-color: #faf9f7;">
  <div class="col-11 col-sm-8 col-md-6 col-lg-4 col-xl-3">
    <div class="card border-0 shadow-sm rounded-4 p-4 p-md-5 bg-white">
      <div class="text-center mb-4">
        <h3 class="fw-bold mb-2" style="color: #1a1a1a; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;">Welcome back</h3>
        <p class="text-muted" style="font-size: 0.95rem;">Log in or <%= link_to "Create account", new_user_registration_path, class: "text-decoration-none fw-medium", style: "color: #b39c84;" %></p>
      </div>

      <% if flash[:alert] %>
        <div class="alert alert-danger rounded-3 border-0 bg-danger bg-opacity-10 text-danger small py-2 px-3 mb-4">
          <%= flash[:alert] %>
        </div>
      <% end %>

      <% if flash[:notice] %>
        <div class="alert alert-success rounded-3 border-0 bg-success bg-opacity-10 text-success small py-2 px-3 mb-4">
          <%= flash[:notice] %>
        </div>
      <% end %>

      <%= simple_form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
        <div class="form-floating mb-3">
          <%= f.input_field :email, class: "form-control border-0 bg-light rounded-3 shadow-none",
                      required: true,
                      autofocus: true,
                      input_html: { autocomplete: "email" },
                      placeholder: "Email address" %>
          <%= f.label :email, "Email address", class: "text-muted" %>
        </div>
        
        <div class="form-floating mb-4">
          <%= f.input_field :password, class: "form-control border-0 bg-light rounded-3 shadow-none",
                      required: true,
                      input_html: { autocomplete: "current-password" },
                      placeholder: "Password" %>
          <%= f.label :password, "Password", class: "text-muted" %>
        </div>

        <div class="d-flex justify-content-between align-items-center mb-4">
          <div class="form-check">
            <%= f.check_box :remember_me, class: "form-check-input border-secondary shadow-none" if devise_mapping.rememberable? %>
            <%= f.label :remember_me, "Remember me", class: "form-check-label text-muted small" if devise_mapping.rememberable? %>
          </div>
          
          <%- if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
            <%= link_to "Forgot password?", new_password_path(resource_name), class: "text-decoration-none fw-medium", style: "color: #b39c84; font-size: 0.85rem;" %>
          <% end %>
        </div>

        <div class="d-grid gap-2">
          <%= f.button :submit, "Log in", class: "btn rounded-pill fw-medium shadow-sm py-2", style: "background-color: #b39c84; color: white; border: none; font-size: 1.05rem; transition: all 0.2s ease;" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
